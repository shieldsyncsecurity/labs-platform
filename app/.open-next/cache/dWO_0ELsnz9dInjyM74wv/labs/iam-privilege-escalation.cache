icy\\\"}],\\\", \\\",[\\\"$\\\",\\\"code\\\",\\\"code-1\\\",{\\\"children\\\":\\\"iam:PutUserPolicy\\\"}],\\\", \\\",[\\\"$\\\",\\\"code\\\",\\\"code-2\\\",{\\\"children\\\":\\\"iam:CreatePolicyVersion\\\"}],\\\",\\\\n\\\",[\\\"$\\\",\\\"code\\\",\\\"code-3\\\",{\\\"children\\\":\\\"iam:SetDefaultPolicyVersion\\\"}],\\\", and \\\",[\\\"$\\\",\\\"code\\\",\\\"code-4\\\",{\\\"children\\\":\\\"iam:PassRole\\\"}],\\\" (with a compute service) are all\\\\n\\\",[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"privilege-escalation primitives\\\"}],\\\". Granting any of them on \\\",[\\\"$\\\",\\\"code\\\",\\\"code-5\\\",{\\\"children\\\":\\\"Resource: \\\\\\\"*\\\\\\\"\\\"}],\\\" quietly\\\\nmakes a \\\\\\\"limited\\\\\\\" identity an admin. Scope IAM-write actions to specific resources,\\\\nor don't grant them at all — and use \\\",[\\\"$\\\",\\\"code\\\",\\\"code-6\\\",{\\\"children\\\":\\\"simulate-principal-policy\\\"}],\\\" in CI to catch it.\\\"]}]\\n28:[\\\"$\\\",\\\"h2\\\",\\\"h2-9\\\",{\\\"children\\\":\\\"Cleanup\\\"}]\\n29:[\\\"$\\\",\\\"p\\\",\\\"p-10\\\",{\\\"children\\\":[\\\"Nothing to do — the account is wiped (\\\",[\\\"$\\\",\\\"code\\\",\\\"code-0\\\",{\\\"children\\\":\\\"aws-nuke\\\"}],\\\") and recycled when your session ends.\\\"]}]\\n2a:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:col-span-1\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:sticky lg:top-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2b\\\",null,{\\\"slug\\\":\\\"iam-privilege-escalation\\\",\\\"objectives\\\":[{\\\"id\\\":\\\"admin-detached\\\",\\\"description\\\":\\\"AdministratorAccess (or any admin-equivalent managed/inline policy) is no longer attached to pipeline-deployer.\\\"},{\\\"id\\\":\\\"escalation-primitive-removed\\\",\\\"description\\\":\\\"The LabDeployerPolicy default version no longer grants iam:AttachUserPolicy (or other IAM write actions) on Resource '*'.\\\"},{\\\"id\\\":\\\"deployer-still-works\\\",\\\"description\\\"