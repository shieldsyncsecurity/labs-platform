td\",\"td-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"DataBucketName\"}]}]]}],[\"$\",\"tr\",\"tr-1\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":[\"Public-via-\",[\"$\",\"strong\",\"strong-0\",{\"children\":\"ACL\"}],\" bucket\"]}],[\"$\",\"td\",\"td-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"children\":\"AssetsBucketName\"}]}]]}],[\"$\",\"tr\",\"tr-2\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"children\":\"Over-privileged user\"}],[\"$\",\"td\",\"td-1\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"auditor\"}],\" (path \",[\"$\",\"code\",\"code-1\",{\"children\":\"/lab/\"}],\")\"]}]]}]]}]]}],\"\\n\",[\"$\",\"blockquote\",\"blockquote-1\",{\"children\":[\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[\"Don't delete the buckets — you're graded on \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"fixing\"}],\" them, not removing them.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"h2\",\"h2-1\",{\"children\":\"Your mission (the grader checks these)\"}],\"\\n\",[\"$\",\"ol\",\"ol-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"No public buckets\"}],\" — no anonymous read on any lab bucket.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Encryption required\"}],\" — each bucket denies unencrypted \",[\"$\",\"code\",\"code-0\",{\"children\":\"PutObject\"}],\".\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"TLS only\"}],\" — each bucket denies non-HTTPS requests.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Least-privilege IAM\"}],\" — \",[\"$\",\"code\",\"code-0\",{\"children\":\"auditor\"}],\" no longer has \",[\"$\",\"code\",\"code-1\",{\"children\":\"s3:*\"}],\" on \",[\"$\",\"code\",\"code-2\",{\"children\":\"*\"}],\".\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"hr\",\"hr-0\",{}],\"\\n\",[\"$\",\"h2\",\"h2-2\",{\"children\":\"Step 1 — Recon: prove the exposure\"}],\"\\n\",[\"$\",\"pre\",\"pre-0\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# List your lab buckets\\naws s3api list-buckets --query \\\"Buckets[?starts_with(Name,'sslab-')].Name\\\"\\n\\n# Which are public? (run for each bucket)\\naws s3api get-bucket-policy-status --bucket <data-bucket>      # -> IsPublic: true\\naws s3api get-bucket-acl          --bucket <assets-bucket>     # -> a grant to AllUsers\\n\"}]}],\"\\n\",\"$L12\",\"\\n\",\"$L13\",\"\\n\",\"$L14\",\"\\n\",\"$L15\",\"\\n\",\"$L16\",\"\\n\",\"$L17\",\"\\n\",\"$L18\",\"\\n\",\"$L19\",\"\\n\",\"$L1a\",\"\\n\",\"$L1b\",\"\\n\",\"$L1c\",\"\\n\",\"$L1d\",\"\\n\",\"$L1e\",\"\\n\",\"$L1f\",\"\\n\",\"$L20\",\"\\n\",\"$L21\",\"\\n\",\"$L22\",\"\\n\",\"$L23\",\"\\n\",\"$L24\",\"\\n\",\"$L25\",\"\\n\",\"$L26\",\"\\n\",\"$L27\",\"\\n\",\"$L28\",\"\\n\",\"$L29\",\"\\n\",\"$L2a\",\"\\n\",\"$L2b\",\"\\n\",\"$L2c\"]}]}],\"$L2d\"]}]]}]\n2e:I[25844,[\"/_next/static/chunks/1k7z9_rdqaoj6.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/3-kvj8gfht59g.js\"],\"LabPanel\"]\n12:[\"$\",\"p\",\"p-3\",{\"children\":\"Confirm anonymous read actually works (no credentials):\"}]\n13:[\"$\",\"pre\",\"pre-1\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"curl -s \\\"https://<data-bucket>.s3.amazonaws.com/customers.csv\\\"   # you'll see the fake data\\n\"}]}]\n14:[\"$\",\"h2\",\"h2-3\",{\"children\":\"Step 2 — Shut the public access\"}]\n15:[\"$\",\"p\",\"p-4\",{\"children\":[\"Belt \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"and\"}],\" braces — turn on Block Public Access at the \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"account\"}],\" level (catches\\nfuture mistakes too) and the \",[\"$\",\"strong\",\"strong-2\",{\"children\":\"bucket\"}],\" level, then remove the actual public grants.\"]}]\n16:[\"$\",\"pre\",\"pre-2\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"ACCT=$(aws sts get-caller-identity --query Account --output text)\\n\\n# Account-wide guardrail\\naws s3control put-public-access-block --account-id \\\"$ACCT\\\" \\\\\\n  --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true\\n\\n# Remove the public BUCKET POLICY on the data bucket\\naws s3api delete-bucket-policy --bucket <data-bucket>\\n\\n# Kill the public ACL on the assets bucket: disable ACLs + reset to private\\naws s3api put-bucket-ownership-controls --bucket <assets-bucket> \\\\\\n  --ownership-controls 'Rules=[{ObjectOwnership=BucketOwnerEnforced}]'\\n\\n# Per-bucket Block Public Access (do for BOTH buckets)\\naws s3api put-public-access-block --bucket <bucket> \\\\\\n  --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true\\n\"}]}]\n17:[\"$\",\"p\",\"p-5\",{\"children\":[\"Re-run the \",[\"$\",\"code\",\"code-0\",{\"children\":\"curl\"}],\" from Step 1 — it should now be \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"AccessDenied\"}],\".\"]}]\n18:[\"$\",\"h2\",\"h2-4\",{\"children\":\"Step 3 — Require encryption at rest\"}]\n19:[\"$\",\"p\",\"p-6\",{\"children\":[\"Turn on default encryption \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"and\"}],\" add a bucket policy that \",[\"$\",\"em\",\"em-0\",{\"children\":\"rejects\"}],\" any\\nunencrypted upload (the grader looks for the explicit deny):\"]}]\n1a:[\"$\",\"pre\",\"pre-3\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws s3api put-bucket-encryption --bucket <bucket> \\\\\\n  --server-side-encryption-configuration '{\\\"Rules\\\":[{\\\"ApplyServerSideEncryptionByDefault\\\":{\\\"SSEAlgorithm\\\":\\\"AES256\\\"}}]}'\\n\"}]}]\n1b:[\"$\",\"p\",\"p-7\",{\"children\":\"Add this statement to each bucket's policy (Step 4 shows the combined policy):\"}]\n1c:[\"$\",\"pre\",\"pre-4\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-json\",\"children\":\"{ \\\"Sid\\\":\\\"DenyUnEncryptedPuts\\\",\\\"Effect\\\":\\\"Deny\\\",\\\"Principal\\\":\\\"*\\\",\\n  \\\"Action\\\":\\\"s3:PutObject\\\",\\\"Resource\\\":\\\"arn:aws:s3:::<bucket>/*\\\",\\n  \\\"Condition\\\":{\\\"StringNotEquals\\\":{\\\"s3:x-amz-server-side-encryption\\\":[\\\"AES256\\\",\\\"aws:kms\\\"]}} }\\n\"}]}]\n1d:[\"$\",\"h2\",\"h2-5\",{\"children\":\"Step 4 — Require TLS (HTTPS) — and apply the combined policy\"}]\n1e:[\"$\",\"p\",\"p-8\",{\"children\":[\"A single hardened bucket policy can carry both the encryption and TLS denies.\\nSave as \",[\"$\",\"code\",\"code-0\",{\"children\":\"secure-policy.json\"}],\" (substitute the bucket name), then apply to \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"each\"}],\" bucket:\"]}]\n1f:[\"$\",\"pre\",\"pre-5\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-json\",\"children\":\"{ \\\"Version\\\":\\\"2012-10-17\\\",\\\"Statement\\\":[\\n  { \\\"Sid\\\":\\\"DenyUnEncryptedPuts\\\",\\\"Effect\\\":\\\"Deny\\\",\\\"Principal\\\":\\\"*\\\",\\n    \\\"Action\\\":\\\"s3:PutObject\\\",\\\"Resource\\\":\\\"arn:aws:s3:::<bucket>/*\\\",\\n    \\\"Condition\\\":{\\\"StringNotEquals\\\":{\\\"s3:x-amz-server-side-encryption\\\":[\\\"AES256\\\",\\\"aws:kms\\\"]}} },\\n  { \\\"Sid\\\":\\\"DenyInsecureTransport\\\",\\\"Effect\\\":\\\"Deny\\\",\\\"Principal\\\":\\\"*\\\",\\n    \\\"Action\\\":\\\"s3:*\\\",\\\"Resource\\\":[\\\"arn:aws:s3:::<bucket>\\\",\\\"arn:aws:s3:::<bucket>/*\\\"],\\n    \\\"Condition\\\":{\\\"Bool\\\":{\\\"aws:SecureTransport\\\":\\\"false\\\"}} }\\n]}\\n\"}]}]\n20:[\"$\",\"pre\",\"pre-6\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws s3api put-bucket-policy --bucket <bucket> --policy file://secure-policy.json\\n\"}]}]\n21:[\"$\",\"h2\",\"h2-6\",{\"children\":\"Step 5 — Least-privilege the IAM user\"}]\n22:[\"$\",\"p\",\"p-9\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"auditor\"}],\" should only read the two lab buckets — not \",[\"$\",\"code\",\"code-1\",{\"children\":\"s3:*\"}],\" on everything.\"]}]\n23:[\"$\",\"pre\",\"pre-7\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"# Remove the over-broad inline policy\\naws iam delete-user-policy --user-name auditor --policy-name s3-full-access-everywhere\\n\\n# Replace with a scoped one (save as scoped.json first)\\naws iam put-user-policy --user-name auditor --policy-name s3-read-lab-buckets \\\\\\n  --policy-document file://scoped.json\\n\"}]}]\n24:[\"$\",\"p\",\"p-10\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"scoped.json\"}],\":\"]}]\n25:[\"$\",\"pre\",\"pre-8\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-json\",\"children\":\"{ \\\"Version\\\":\\\"2012-10-17\\\",\\\"Statement\\\":[\\n  { \\\"Effect\\\":\\\"Allow\\\",\\\"Action\\\":[\\\"s3:GetObject\\\",\\\"s3:ListBucket\\\"],\\n    \\\"Resource\\\":[\\\"arn:aws:s3:::sslab-data-*\\\",\\\"arn:aws:s3:::sslab-data-*/*\\\",\\n                \\\"arn:aws:s3:::sslab-assets-*\\\",\\\"arn:aws:s3:::sslab-assets-*/*\\\"] } ]}\\n\"}]}]\n26:[\"$\",\"hr\",\"hr-1\",{}]\n27:[\"$\",\"h2\",\"h2-7\",{\"children\":\"Verify you passed\"}]\n28:[\"$\",\"pre\",\"pre-9\",{\"children\":[\"$\",\"code\",\"code-0\",{\"className\":\"language-bash\",\"children\":\"aws s3api get-bucket-policy-status --bucket <bucket>          # IsPublic: false (both)\\naws iam list-user-policies        --user-name auditor        # no 's3-full-access-everywhere'\\naws iam get-user-policy --user-name auditor --policy-name s3-read-lab-buckets   # scoped, no \\\"*\\\"\\n\"}]}]\n29:[\"$\",\"h2\",\"h2-8\",{\"children\":\"Hints\"}]\n2a:[\"$\",\"ul\",\"ul-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"code\",\"code-0\",{\"children\":\"get-bucket-policy-status\"}],\" is the fastest \\\"is it public?\\\" check.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":\"Account-level Block Public Access overrides any bucket that tries to be public — it's your strongest single control.\"}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[\"Default encryption ≠ \",[\"$\",\"em\",\"em-0\",{\"children\":\"required\"}],\" encryption. Only the \",[\"$\",\"code\",\"code-0\",{\"children\":\"Deny\"}],\" policy forces callers to ask for it.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[\"Scope IAM to the buckets, not to \",[\"$\",\"code\",\"code-0\",{\"children\":\"*\"}],\" — wildcards are how one leaked key becomes a full breach.\"]}],\"\\n\"]}]\n2b:[\"$\",\"h2\",\"h2-9\",{\"children\":\"Cleanup\"}]\n2c:[\"$\",\"p\",\"p-11\",{\"children\":[\"Nothing to do — when your session ends the account is wiped (\",[\"$\",\"code\",\"code-0\",{\"children\":\"aws-nuke\"}],\") and returned to the pool. There's no bill to worry about.\"]}]\n2d:[\"$\",\"div\",null,{\"className\":\"lg:col-span-1\",\"children\":[\"$\",\"div\",null,{\"className\":\"lg:sticky lg:top-6\",\"children\":[[\"$\",\"$L2e\",null,{\"slug\":\"s3-misconfiguration-audit\",\"objectives\":[{\"id\":\"no-public-buckets\",\"description\":\"No bucket in the account allows anonymous public read.\"},{\"id\":\"encryption-required\",\"description\":\"Every Lab bucket has a bucket policy denying unencrypted PutObject.\"},{\"id\":\"tls-only\",\"description\":\"Every Lab bucket denies non-TLS requests.\"},{\"id\":\"least-privilege-iam\",\"description\":\"The lab IAM user no longer has s3:* on Resource '*'.\"}],\"ready\":true}],[\"$\",\"div\",null,{\"className\":\"mt-3 flex flex-wrap gap-1.5\",\"children\":[[\"$\",\"span\",\"S3\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"S3\"}],[\"$\",\"span\",\"IAM\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"children\":\"IAM\"}],[\"$\",\"span\",\"Encryption\",{\"className\":\"rounded-md border border-line px-2 py-0.5 font-mono text-xs text-muted\",\"chil