# ShieldSync Labs app — environment

# Engine (Session Engine) URL. Local dev = http://localhost:4000.
# In production this is the engine's AWS Lambda Function URL.
ENGINE_URL=http://localhost:4000

# --- Amazon Cognito (real auth) ---------------------------------------------
# Leave these blank to keep using the local mock (Continue with Google/LinkedIn
# mints a demo user). Set NEXT_PUBLIC_AUTH_MODE=cognito to turn the real flow on.
NEXT_PUBLIC_AUTH_MODE=
COGNITO_REGION=us-east-1
# Hosted UI domain, e.g. shieldsync-labs.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# Public origin of THIS app (must match the Cognito callback URLs exactly).
# Local: http://localhost:3001   Prod: https://labs.shieldsyncsecurity.com
APP_URL=http://localhost:3001

# Random secret used to sign our own session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=
