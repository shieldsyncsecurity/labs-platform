# ShieldSync Labs app — environment

# Engine (Session Engine) URL. Local dev = http://localhost:4000.
# In production this is the engine's AWS Lambda Function URL.
ENGINE_URL=http://localhost:4000

# --- Amazon Cognito (real auth) ---------------------------------------------
# Leave these blank to keep using the local mock (Continue with Google/LinkedIn
# mints a demo user). Set NEXT_PUBLIC_AUTH_MODE=cognito to turn the real flow on.
NEXT_PUBLIC_AUTH_MODE=
COGNITO_REGION=us-east-1
# Hosted UI domain, e.g. shieldsync-labs.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# Public origin of THIS app (must match the Cognito callback URLs exactly).
# Local: http://localhost:3001   Prod: https://labs.shieldsyncsecurity.com
APP_URL=http://localhost:3001

# Random secret used to sign our own session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# --- Payments (Paytm) --------------------------------------------------------
# Master switch for the whole payment flow. Leave UNSET/empty until Paytm
# production credentials are wired (see PAYTM_* in wrangler.jsonc + secrets).
# While unset:
#   /api/payments/checkout -> 503   /paytm/confirm + /paytm/callback -> 404
PAYMENTS_LIVE=

# Internal secret used ONLY to sign dev-simulator order tokens (mock-pay route).
# Must be >=16 chars in production or signing fails closed. NOT a provider secret.
MOCK_PAYMENT_SECRET=

# Set to 1 ONLY in dev/preview to enable the simulated gateway (/mock-pay).
# MUST stay unset in production — it is a "mark this paid" button.
ALLOW_MOCK_PAY=
