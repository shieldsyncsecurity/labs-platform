# ShieldSync Enterprise app -- environment

# Enterprise engine base URL. Local dev = http://localhost:4001 (a different
# port than the labs engine's 4000, since they are separate services).
# In production this is the enterprise engine's AWS endpoint.
ENT_ENGINE_URL=http://localhost:4001

# Shared secret the engine requires on the x-engine-token header. Server-only
# (read in lib/server/ent-engine.ts). NEVER expose this to the browser.
# In production this MUST be set as a Cloudflare Worker secret
# (`wrangler secret put ENT_ENGINE_SECRET`), not as a `vars` entry.
ENT_ENGINE_SECRET=

# Public origin of THIS app. Local: http://localhost:3002
# Prod: https://enterprise.shieldsyncsecurity.com (placeholder, TBD)
APP_URL=http://localhost:3002

# Random secret used to sign this app's own session cookie (employer auth --
# not built yet). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# In production this MUST be set as a Cloudflare Worker secret
# (`wrangler secret put SESSION_SECRET`), not as a `vars` entry.
SESSION_SECRET=

# Enables the DEV-ONLY employer portal sign-in (app/api/portal/dev-login).
# Set to any non-empty value to turn it on locally. TODO: delete this whole
# flag + the dev-login route once Cognito enterprise-pool auth ships -- see
# lib/server/portal-session.ts.
PORTAL_DEV_LOGIN=1
